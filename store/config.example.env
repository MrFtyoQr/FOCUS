# Copia a store/config.env y ajusta antes de publicar en tiendas.
# NO subas config.env ni keystores al repositorio.

# Identificador único (Play Console + App Store Connect deben coincidir)
BUNDLE_ID=com.treetech.hiperapp

APP_DISPLAY_NAME=HiperApp
ORGANIZATION=Tree Tech Solutions

# Android upload keystore (rutas relativas a android/)
ANDROID_KEYSTORE_FILE=app/upload-keystore.jks
ANDROID_KEY_ALIAS=upload
# ANDROID_STORE_PASSWORD=
# ANDROID_KEY_PASSWORD=

# iOS (solo en Mac con Xcode)
# APPLE_TEAM_ID=
# APPLE_DEVELOPER_EMAIL=
